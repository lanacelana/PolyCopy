{
  "manifest_version": 3,
  "name": "Smart Multi-Copy Highlight, Mate",
  "version": "1.4",
  "description": "Highlight heaps of text to grab 'em all at once with premium styles and colors. Fair dinkum!",
  "author": "lncln",
  "permissions": [
    "storage",
    "clipboardWrite",
    "clipboardRead",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icon_active_16.png",
    "32": "icon_active_32.png",
    "48": "icon_active_48.png",
    "128": "icon_active_128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon_active_16.png",
      "32": "icon_active_32.png",
      "48": "icon_active_48.png",
      "128": "icon_active_128.png"
    },
    "default_popup": "popup.html"
  }
}